{
  "name": "@s-h-a-d-o-w/oxlint-config",
  "version": "1.1.0",
  "description": "My personal default oxlint and oxfmt configs.",
  "type": "module",
  "license": "MIT",
  "author": "Andreas Opferkuch <andreas.opferkuch@gmail.com>",
  "repository": "s-h-a-d-o-w/oxlint-config",
  "exports": {
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc",
    "prepack": "del-cli dist && tsc -p tsconfig.prod.json",
    "prepublishOnly": "pnpm typecheck && oxlint && oxfmt --check"
  },
  "peerDependencies": {
    "oxfmt": "*",
    "oxlint": "*",
    "oxlint-tsgolint": "*"
  },
  "devDependencies": {
    "del-cli": "^7.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.2"
  },
  "keywords": [
    "config",
    "defaults",
    "lint",
    "linting",
    "oxlint"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
